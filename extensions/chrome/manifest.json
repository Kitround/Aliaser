{
  "manifest_version": 3,
  "name": "Aliaser",
  "version": "1.0.0",
  "description": "Manage your email aliases",
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
